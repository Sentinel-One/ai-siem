# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Claude-specific files #
########################
CLAUDE.md
.claude/
*.claude
.cursorrules
.claude-config

# Local documentation #
#######################
LOCAL_*.md
LOCAL_*.txt
*_LOCAL_ONLY.*
