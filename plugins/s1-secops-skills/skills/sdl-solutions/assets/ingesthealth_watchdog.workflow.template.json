          "name": "Find Silent Devices",
          "action_type": "http_request",
          "public_action_id": null,
          "method": "post",
          "url": "{{Connection.protocol}}{{Connection.url}}/sdl/v2/api/queries",
          "url_path": null,
          "url_prefix": null,
          "payload": "{\n  \"queryType\": \"PQ\",\n  \"tenant\": true,\n  \"startTime\": \"{{Function.DELTA_NOW(1)}}\",\n  \"endTime\": \"{{Function.DATETIME_NOW()}}\",\n  \"queryPriority\": \"HIGH\",\n  \"pq\": {\n    \"query\": \"| left join base = (| dataset 'config://datatables/ingestHealthSourceStats' | filter active_hours >= 151 | columns devkey, source, device, mean_ev, last_seen, active_hours, total_gib), live = (sca:bytesToCharge=* dataSource.name=* | let device = (device.name ? device.name : (endpoint.name ? endpoint.name : (agent.uuid ? agent.uuid : (src_endpoint.hostname ? src_endpoint.hostname : (hostname ? hostname : dataSource.name))))) | group cur_events = count() by source = dataSource.name, device | let devkey = format('%s||%s', source, device) | columns devkey, cur_events) on devkey | filter !(cur_events = *) | columns devkey, source, device, mean_ev, active_hours, last_seen, total_gib | sort -mean_ev | limit 100\",\n    \"resultType\": \"TABLE\"\n  }\n}",
          "parameters": [],
          "retry_on_status_codes": [
            500
          ],
          "ssl_verification": true,
          "timeout": 90,
          "headers": {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          "use_authentication_data": true,
          "use_proxy": false,
          "redirect_follow": true,
