{
  "name": "Cloudflare - Automated WAF Policy Enforcement based on Risk Score",
  "description": "Cloudflare Logpush continuously streams WAF event data, including granular WAF Attack Scores, into the SentinelOne AI SIEM. When the SIEM detects a sustained threshold of high-risk traffic (e.g., Attack Score < 5) targeting a specific application path, it triggers this Hyperautomation workflow. The workflow immediately invokes the Cloudflare Rulesets API to dynamically escalate the associated WAF Custom Rule from \"Log\" or \"Managed Challenge\" to a hard \"Block\" action.\n",
  "actions": [
    {
      "action": {
        "type": "singularity_response_trigger",
        "tag": "core_action",
        "connection_id": null,
        "connection_name": null,
        "use_connection_name": false,
        "integration_id": null,
        "data": {
          "name": "Singularity Response Trigger",
          "action_type": "singularity_response_trigger",
          "filter_groups": [
            {
              "condition": {
                "operator": "and",
                "conditions": [
                  {
                    "input_value": "severity",
                    "compared_value": "[\"CRITICAL\",\"HIGH\"]",
                    "comparison_operator": "in"
                  },
                  {
                    "input_value": "detectionSource.product",
                    "compared_value": "STAR",
                    "comparison_operator": "equals"
                  },
                  {
                    "input_value": "name",
                    "compared_value": "Cloudflare WAF Risk",
                    "comparison_operator": "contains"
                  }
                ]
              },
              "is_disabled": false,
              "run_automatically": false,
              "event_type": "alert",
              "event_subtypes": [
                "CREATE"
              ]
            }
          ]
        },
        "state": "active",
        "description": null,
        "client_data": {
