          "payload": "{\"query\": \"mutation ResolveAlreadyMitigated { alertTriggerActions(actions: [{ id: \\\"S1/alert/statusUpdate\\\", payload: { status: { value: \\\"RESOLVED\\\" } } }, { id: \\\"S1/alert/addNote\\\", payload: { note: { value: \\\"{{Function.HTML_ENCODE(local_var.note)}}\\\" } } }], filter: { or: [ { and: [ { fieldId: \\\"id\\\", stringEqual: { value: \\\"{{singularity-response-trigger.data.id}}\\\" } } ] } ] }) { ... on ActionsTriggered { actions { actionId success { id } failure { id } skip { id } } } } }\"}",
